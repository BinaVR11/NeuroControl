<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NeuroControl - Hand Tracking 3D</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- MediaPipe para el tracking de manos -->
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/hands/hands.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/drawing_utils/drawing_utils.js"></script>
    <!-- Three.js para el mundo 3D -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        body { margin: 0; background-color: #020617; overflow: hidden; font-family: 'Inter', sans-serif; }
        #video-container {
            position: fixed;
            bottom: 20px;
            left: 20px;
            width: 240px;
            height: 180px;
            border-radius: 16px;
            overflow: hidden;
            border: 2px solid #3b82f6;
            z-index: 100;
            background: black;
            transform: scaleX(-1); /* Espejo */
        }
        canvas.output_canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }
        .ui-panel {
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
    </style>
</head>
<body>

    <!-- Overlay de Interfaz -->
    <div class="fixed inset-0 pointer-events-none z-50 p-8 flex flex-col justify-between">
        <div class="flex justify-between items-start">
            <div class="ui-panel p-6 rounded-3xl pointer-events-auto">
                <h1 class="text-white font-black text-2xl tracking-tighter italic">NEURO<span class="text-blue-500">CONTROL</span></h1>
                <p class="text-slate-400 text-[10px] uppercase tracking-widest font-bold">Interfaz Gestual de Alta Precisión</p>
                <div id="status" class="mt-4 flex items-center gap-2">
                    <span id="status-dot" class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
                    <span id="status-text" class="text-xs text-white font-mono uppercase tracking-tighter">Inicializando IA...</span>
                </div>
            </div>

            <div class="ui-panel p-4 rounded-2xl pointer-events-auto text-right">
                <p class="text-[10px] text-slate-500 font-bold uppercase">Instrucciones</p>
                <p class="text-white text-xs mt-1">Mueve tu mano frente a la cámara.<br>Pinza (pulgar e índice) para "agarrar".</p>
            </div>
        </div>

        <div class="flex justify-end gap-4 pointer-events-auto">
            <div class="ui-panel px-6 py-4 rounded-2xl flex flex-col items-end">
                <span class="text-[10px] text-blue-400 font-bold">POSICIÓN RELATIVA</span>
                <span id="coords" class="text-white font-mono text-xl tracking-tighter">X: 0.00 Y: 0.00</span>
            </div>
        </div>
    </div>

    <!-- Feed de Video y Tracking (Oculto pero funcional) -->
    <div id="video-container">
        <video id="input_video" class="hidden"></video>
        <canvas id="output_canvas" class="output_canvas"></canvas>
    </div>

    <script>
        const videoElement = document.getElementById('input_video');
        const canvasElement = document.getElementById('output_canvas');
        const canvasCtx = canvasElement.getContext('2d');
        const statusText = document.getElementById('status-text');
        const statusDot = document.getElementById('status-dot');
        const coordsDisplay = document.getElementById('coords');

        let scene, camera, renderer, sphere, particleSystem;
        let targetX = 0, targetY = 0, targetZ = 0;
        let isHandActive = false;

        // --- INICIALIZAR THREE.JS ---
        function init3D() {
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x020617);
            scene.fog = new THREE.FogExp2(0x020617, 0.1);

            camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.z = 5;

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            document.body.appendChild(renderer.domElement);

            // Objeto Principal: Esfera de Energía
            const geo = new THREE.IcosahedronGeometry(1, 15);
            const mat = new THREE.MeshStandardMaterial({ 
                color: 0x3b82f6, 
                wireframe: true,
                emissive: 0x1e3a8a,
                emissiveIntensity: 0.5
            });
            sphere = new THREE.Mesh(geo, mat);
            scene.add(sphere);

            // Partículas de fondo
            const particlesGeo = new THREE.BufferGeometry();
            const particlesCount = 2000;
            const posArray = new Float32Array(particlesCount * 3);
            for(let i=0; i < particlesCount * 3; i++) {
                posArray[i] = (Math.random() - 0.5) * 20;
            }
            particlesGeo.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
            const particlesMat = new THREE.PointsMaterial({ size: 0.02, color: 0x3b82f6 });
            particleSystem = new THREE.Points(particlesGeo, particlesMat);
            scene.add(particleSystem);

            // Luces
            const pLight = new THREE.PointLight(0x3b82f6, 2, 10);
            pLight.position.set(2, 2, 2);
            scene.add(pLight);
            scene.add(new THREE.AmbientLight(0xffffff, 0.2));

            animate();
        }

        function animate() {
            requestAnimationFrame(animate);
            
            // Suavizado de movimiento (Lerp)
            sphere.position.x += (targetX - sphere.position.x) * 0.1;
            sphere.position.y += (targetY - sphere.position.y) * 0.1;
            sphere.scale.setScalar(1 + targetZ);

            sphere.rotation.y += 0.01;
            sphere.rotation.x += 0.005;
            
            particleSystem.rotation.y += 0.001;

            renderer.render(scene, camera);
        }

        // --- CONFIGURAR MEDIAPIPE ---
        const hands = new Hands({
            locateFile: (file) => `https://cdn.jsdelivr.net/npm/@mediapipe/hands/${file}`
        });

        hands.setOptions({
            maxNumHands: 1,
            modelComplexity: 1,
            minDetectionConfidence: 0.7,
            minTrackingConfidence: 0.7
        });

        hands.onResults((results) => {
            canvasCtx.save();
            canvasCtx.clearRect(0, 0, canvasElement.width, canvasElement.height);
            canvasCtx.drawImage(results.image, 0, 0, canvasElement.width, canvasElement.height);

            if (results.multiHandLandmarks && results.multiHandLandmarks.length > 0) {
                if(!isHandActive) {
                    statusDot.classList.replace('bg-red-500', 'bg-emerald-500');
                    statusText.innerText = "Mano Detectada";
                    isHandActive = true;
                }

                const hand = results.multiHandLandmarks[0];
                
                // Dibujar puntos en el pequeño canvas de vista previa
                drawConnectors(canvasCtx, hand, HAND_CONNECTIONS, {color: '#3b82f6', lineWidth: 5});
                drawLandmarks(canvasCtx, hand, {color: '#ffffff', lineWidth: 2, radius: 3});

                // Extraer coordenadas del índice (punto 8)
                // Invertimos X porque el video está espejado
                const indexTip = hand[8];
                const thumbTip = hand[4];

                // Convertir coordenadas 0-1 a espacio 3D de Three.js (-5 a 5)
                targetX = (1 - indexTip.x) * 10 - 5;
                targetY = -(indexTip.y * 8 - 4);

                // Calcular distancia pulgar-índice para "Z" o escala
                const dist = Math.hypot(indexTip.x - thumbTip.x, indexTip.y - thumbTip.y);
                targetZ = dist * 2; 

                coordsDisplay.innerText = `X: ${targetX.toFixed(2)} Y: ${targetY.toFixed(2)}`;

            } else {
                if(isHandActive) {
                    statusDot.classList.replace('bg-emerald-500', 'bg-red-500');
                    statusText.innerText = "Buscando Mano...";
                    isHandActive = false;
                }
            }
            canvasCtx.restore();
        });

        const cameraFeed = new Camera(videoElement, {
            onFrame: async () => {
                await hands.send({image: videoElement});
            },
            width: 640,
            height: 480
        });

        window.onload = () => {
            init3D();
            cameraFeed.start();
        };

        window.onresize = () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        };
    </script>
</body>
</html>
